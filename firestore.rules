rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'Admin';
    }

    function isEditor() {
      return isSignedIn() && (getUserRole() == 'Editor' || getUserRole() == 'Admin');
    }

    // 1. Users Collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        isAdmin() || 
        (request.auth.uid == userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['photoURL', 'displayName', 'lastLogin']))
      );
    }

    // 2. Tickets
    match /tickets/{ticketId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isEditor();
      allow update: if isSignedIn() && isEditor();
      allow delete: if isSignedIn() && isAdmin();
    }

    // 3. Case Studies
    match /caseStudies/{caseId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isEditor();
      allow update: if isSignedIn() && isEditor();
      allow delete: if isSignedIn() && isAdmin();
    }

    // 4. Metadata
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isAdmin();
    }

    match /pics/{picId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isAdmin();
    }
  }
}
